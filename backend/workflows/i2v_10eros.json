{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": { "ckpt_name": "LTX2.3-10Eros_bf16.safetensors" },
    "_meta": { "title": "Checkpoint (incl. video VAE)" }
  },
  "2": {
    "class_type": "CLIPLoader",
    "inputs": { "clip_name": "gemma_3_12b_it_fp8_scaled.safetensors", "type": "ltxv" },
    "_meta": { "title": "Text Encoder (gemma)" }
  },
  "4": {
    "class_type": "VAELoader",
    "inputs": { "vae_name": "LTX23_audio_vae_bf16.safetensors" },
    "_meta": { "title": "Audio VAE" }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "", "clip": ["2", 0] },
    "_meta": { "title": "Positive Prompt" }
  },
  "7": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "blurry, low quality, watermark", "clip": ["2", 0] },
    "_meta": { "title": "Negative Prompt" }
  },
  "8": {
    "class_type": "LTXVConditioning",
    "inputs": { "positive": ["6", 0], "negative": ["7", 0], "frame_rate": 25 },
    "_meta": { "title": "LTXV Conditioning (fps)" }
  },
  "10": {
    "class_type": "LoadImage",
    "inputs": { "image": "reference.png" },
    "_meta": { "title": "Reference Image" }
  },
  "11": {
    "class_type": "LTXVPreprocess",
    "inputs": { "image": ["10", 0], "img_compression": 35 },
    "_meta": { "title": "LTXV Preprocess" }
  },
  "12": {
    "class_type": "LTXVImgToVideo",
    "inputs": {
      "positive": ["8", 0],
      "negative": ["8", 1],
      "vae": ["1", 2],
      "image": ["11", 0],
      "width": 1280,
      "height": 720,
      "length": 121,
      "batch_size": 1,
      "strength": 1.0
    },
    "_meta": { "title": "Img To Video (first frame guide)" }
  },
  "15": {
    "class_type": "LoraLoaderModelOnly",
    "inputs": {
      "model": ["1", 0],
      "lora_name": "ltx-2.3-22b-distilled-lora-384-1.1_cond_safe.safetensors",
      "strength_model": 1.0
    },
    "_meta": { "title": "FIRST STAGE DISTIL" }
  },
  "16": {
    "class_type": "KSamplerSelect",
    "inputs": { "sampler_name": "euler" },
    "_meta": { "title": "Sampler P1" }
  },
  "17": {
    "class_type": "LTXVScheduler",
    "inputs": { "steps": 20, "max_shift": 2.05, "base_shift": 0.95, "stretch": true, "terminal": 0.1 },
    "_meta": { "title": "Scheduler P1" }
  },
  "30": {
    "class_type": "SamplerCustom",
    "inputs": {
      "model": ["15", 0],
      "add_noise": true,
      "noise_seed": 42,
      "cfg": 3.0,
      "positive": ["12", 0],
      "negative": ["12", 1],
      "sampler": ["16", 0],
      "sigmas": ["17", 0],
      "latent_image": ["12", 2]
    },
    "_meta": { "title": "PASS 1 — base render" }
  },
  "41": {
    "class_type": "UpscaleModelLoader",
    "inputs": { "model_name": "ltx-2.3-spatial-upscaler-x2-1.1.safetensors" },
    "_meta": { "title": "Spatial Upscaler model" }
  },
  "42": {
    "class_type": "LTXVLatentUpsampler",
    "inputs": { "samples": ["30", 0], "upscale_model": ["41", 0], "vae": ["1", 2] },
    "_meta": { "title": "Latent x2 spatial upscale" }
  },
  "45": {
    "class_type": "LoraLoaderModelOnly",
    "inputs": {
      "model": ["1", 0],
      "lora_name": "ltx-2.3-22b-distilled-lora-384-1.1_cond_safe.safetensors",
      "strength_model": 1.0
    },
    "_meta": { "title": "SECOND STAGE DISTIL" }
  },
  "46": {
    "class_type": "KSamplerSelect",
    "inputs": { "sampler_name": "euler" },
    "_meta": { "title": "Sampler P2" }
  },
  "47": {
    "class_type": "LTXVScheduler",
    "inputs": { "steps": 8, "max_shift": 2.05, "base_shift": 0.95, "stretch": true, "terminal": 0.1 },
    "_meta": { "title": "Scheduler P2" }
  },
  "40": {
    "class_type": "SamplerCustom",
    "inputs": {
      "model": ["45", 0],
      "add_noise": true,
      "noise_seed": 42,
      "cfg": 1.0,
      "positive": ["12", 0],
      "negative": ["12", 1],
      "sampler": ["46", 0],
      "sigmas": ["47", 0],
      "latent_image": ["42", 0]
    },
    "_meta": { "title": "PASS 2 — refine" }
  },
  "50": {
    "class_type": "VAEDecode",
    "inputs": { "samples": ["40", 0], "vae": ["1", 2] },
    "_meta": { "title": "Video Decode (tiled when decode_tile>0)" }
  },
  "52": {
    "class_type": "LTXVAudioVAEDecode",
    "inputs": { "samples": ["40", 0], "audio_vae": ["4", 0] },
    "_meta": { "title": "Audio Decode" }
  },
  "55": {
    "class_type": "CreateVideo",
    "inputs": { "images": ["50", 0], "audio": ["52", 0], "fps": 25 },
    "_meta": { "title": "Mux A/V" }
  },
  "56": {
    "class_type": "SaveVideo",
    "inputs": { "video": ["55", 0], "filename_prefix": "CinematicConsole/cc-i2v", "format": "mp4", "codec": "h264" },
    "_meta": { "title": "Save Video" }
  }
}
