{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": { "ckpt_name": "sulphur_dev_fp8mixed.safetensors" },
    "_meta": { "title": "Checkpoint (incl. video VAE)" }
  },
  "4": {
    "class_type": "VAELoader",
    "inputs": { "vae_name": "LTX2_audio_vae_bf16.safetensors" },
    "_meta": { "title": "Audio VAE" }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "", "clip": ["1", 1] },
    "_meta": { "title": "Positive Prompt" }
  },
  "7": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "blurry, low quality, watermark", "clip": ["1", 1] },
    "_meta": { "title": "Negative Prompt" }
  },
  "8": {
    "class_type": "LTXVConditioning",
    "inputs": { "positive": ["6", 0], "negative": ["7", 0], "frame_rate": 25 },
    "_meta": { "title": "LTXV Conditioning (fps)" }
  },
  "70": {
    "class_type": "EmptyLTXVLatentVideo",
    "inputs": { "width": 1280, "height": 720, "length": 121, "batch_size": 1 },
    "_meta": { "title": "Empty Video Latent" }
  },
  "15": {
    "class_type": "LoraLoaderModelOnly",
    "inputs": {
      "model": ["1", 0],
      "lora_name": "ltx-2.3-22b-distilled-lora-1.1_fro90_ceil72_condsafe.safetensors",
      "strength_model": 1.0
    },
    "_meta": { "title": "FIRST STAGE DISTIL" }
  },
  "16": {
    "class_type": "KSamplerSelect",
    "inputs": { "sampler_name": "euler" },
    "_meta": { "title": "Sampler P1" }
  },
  "17": {
    "class_type": "LTXVScheduler",
    "inputs": { "steps": 20, "max_shift": 2.05, "base_shift": 0.95, "stretch": true, "terminal": 0.1 },
    "_meta": { "title": "Scheduler P1" }
  },
  "30": {
    "class_type": "SamplerCustom",
    "inputs": {
      "model": ["15", 0],
      "add_noise": true,
      "noise_seed": 42,
      "cfg": 3.0,
      "positive": ["8", 0],
      "negative": ["8", 1],
      "sampler": ["16", 0],
      "sigmas": ["17", 0],
      "latent_image": ["70", 0]
    },
    "_meta": { "title": "PASS 1 — base render" }
  },
  "41": {
    "class_type": "UpscaleModelLoader",
    "inputs": { "model_name": "ltx-2.3-spatial-upscaler-x2-1.1.safetensors" },
    "_meta": { "title": "Spatial Upscaler model" }
  },
  "42": {
    "class_type": "LTXVLatentUpsampler",
    "inputs": { "samples": ["30", 0], "upscale_model": ["41", 0], "vae": ["1", 2] },
    "_meta": { "title": "Latent x2 spatial upscale" }
  },
  "45": {
    "class_type": "LoraLoaderModelOnly",
    "inputs": {
      "model": ["1", 0],
      "lora_name": "ltx-2.3-22b-distilled-lora-1.1_fro90_ceil72_condsafe.safetensors",
      "strength_model": 1.0
    },
    "_meta": { "title": "SECOND STAGE DISTIL" }
  },
  "46": {
    "class_type": "KSamplerSelect",
    "inputs": { "sampler_name": "euler" },
    "_meta": { "title": "Sampler P2" }
  },
  "47": {
    "class_type": "LTXVScheduler",
    "inputs": { "steps": 8, "max_shift": 2.05, "base_shift": 0.95, "stretch": true, "terminal": 0.1 },
    "_meta": { "title": "Scheduler P2" }
  },
  "40": {
    "class_type": "SamplerCustom",
    "inputs": {
      "model": ["45", 0],
      "add_noise": true,
      "noise_seed": 42,
      "cfg": 1.0,
      "positive": ["8", 0],
      "negative": ["8", 1],
      "sampler": ["46", 0],
      "sigmas": ["47", 0],
      "latent_image": ["42", 0]
    },
    "_meta": { "title": "PASS 2 — refine" }
  },
  "50": {
    "class_type": "VAEDecode",
    "inputs": { "samples": ["40", 0], "vae": ["1", 2] },
    "_meta": { "title": "Video Decode (tiled when decode_tile>0)" }
  },
  "52": {
    "class_type": "LTXVAudioVAEDecode",
    "inputs": { "samples": ["40", 0], "audio_vae": ["4", 0] },
    "_meta": { "title": "Audio Decode" }
  },
  "55": {
    "class_type": "CreateVideo",
    "inputs": { "images": ["50", 0], "audio": ["52", 0], "fps": 25 },
    "_meta": { "title": "Mux A/V" }
  },
  "56": {
    "class_type": "SaveVideo",
    "inputs": { "video": ["55", 0], "filename_prefix": "CinematicConsole/cc-t2v", "format": "mp4", "codec": "h264" },
    "_meta": { "title": "Save Video" }
  }
}
